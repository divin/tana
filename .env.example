# Docker Compose Configuration
# Copy this file to .env and customize values as needed

# Version of Tana images to use
# Options:
#   - latest (default) - always pull the latest release
#   - v0.1.0, v1.2.3, etc. - pin to a specific release
# Examples:
#   TANA_VERSION=latest
#   TANA_VERSION=v0.1.0
TANA_VERSION=latest

# Rust logging level for the backend API
# Options: trace, debug, info, warn, error
# Default: info
RUST_LOG=info

# Optional: Custom Docker registry and repository path
# By default, images are pulled from GitHub Container Registry (ghcr.io)
# You can customize this if you've mirrored the images to a different registry
#
# Examples:
#   DOCKER_REGISTRY=docker.io (for Docker Hub)
#   DOCKER_REGISTRY=your-registry.azurecr.io (for Azure Container Registry)
#   DOCKER_REGISTRY=gcr.io (for Google Container Registry)
#
# DOCKER_REGISTRY=ghcr.io
# GITHUB_REPOSITORY=divin/tana
